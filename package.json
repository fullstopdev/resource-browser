{
	"name": "resource-browser",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host 0.0.0.0",
		"dev:ai": "PUBLIC_ASK_AI_ENABLED=true PUBLIC_FIX_AI_ENABLED=true npm run build:cloudflare && wrangler pages dev .svelte-kit/cloudflare --ai AI --compatibility-date=2025-06-01 --compatibility-flag=nodejs_compat",
		"build": "vite build",
		"build:vercel": "ADAPTER=vercel vite build",
		"build:cloudflare": "PUBLIC_FIX_AI_ENABLED=true ADAPTER=cloudflare vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"generate:sitemap": "node scripts/generate-sitemap.mjs",
		"generate:release-notes": "tsx --tsconfig tsconfig.scripts.json scripts/generate-release-notes.ts",
		"embed:crd-corpus": "tsx --tsconfig tsconfig.scripts.json scripts/embed-crd-corpus.ts",
		"embed:eda-docs": "tsx --tsconfig tsconfig.scripts.json scripts/embed-eda-docs.ts",
		"embed:rebuild-manifest": "tsx --tsconfig tsconfig.scripts.json scripts/rebuild-vectorize-manifest.ts",
		"embed:status": "tsx --tsconfig tsconfig.scripts.json scripts/embed-status.ts",
		"warm:cache": "tsx --tsconfig tsconfig.scripts.json scripts/warm-cache.ts",
		"warm:cache:deterministic": "tsx --tsconfig tsconfig.scripts.json scripts/warm-cache.ts",
		"warm:cache:llm": "WARM_ACTIONS=explain,example tsx --tsconfig tsconfig.scripts.json scripts/warm-cache.ts",
		"audit:dependencies": "tsx --tsconfig tsconfig.scripts.json scripts/audit-dependency-corpus.ts",
		"build:dependency-graph": "tsx --tsconfig tsconfig.scripts.json scripts/build-dependency-graph.ts",
		"prebuild": "npm run generate:sitemap && npm run generate:release-notes",
		"deploy:cloudflare": "npm run build:cloudflare && wrangler pages deploy .svelte-kit/cloudflare --project-name=eda-resource-browser",
		"deploy:cloudflare:lean": "PUBLIC_ASK_AI_ENABLED=false PUBLIC_FIX_AI_ENABLED=false npm run build:cloudflare && node scripts/deploy-cloudflare-lean.mjs",
		"deploy:cloudflare:phase1": "npm run build:cloudflare && wrangler pages deploy .svelte-kit/cloudflare --project-name=eda-resource-browser"
	},
	"dependencies": {
		"@xyflow/svelte": "^1.6.0",
		"@xyflow/system": "^0.0.77",
		"ajv": "^8.17.1",
		"d3": "^7.9.0",
		"monaco-editor": "^0.52.2"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250712.0",
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@playwright/test": "^1.49.1",
		"@sveltejs/adapter-cloudflare": "^7.0.0",
		"@sveltejs/adapter-vercel": "^5.10.3",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/vite": "^4.1.11",
		"@types/d3": "^7.4.3",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.9.3",
		"@vitest/browser": "^3.2.3",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"js-yaml": "^4.1.0",
		"playwright": "^1.53.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"svelte-copy": "^2.0.0",
		"tailwindcss": "^4.1.11",
		"tsx": "^4.19.4",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"undici": "7.24.8",
		"vite": "^7.0.4",
		"vite-plugin-devtools-json": "^0.2.0",
		"vitest": "^3.2.3",
		"vitest-browser-svelte": "^0.1.0",
		"wrangler": "^4.98.0"
	}
}
