# Set ADAPTER=vercel for Vercel deployment
# Set ADAPTER=cloudflare (or leave unset) for Cloudflare deployment
ADAPTER=cloudflare

# Ask AI UI (header button + slide-over). On in dev; off in production unless explicitly enabled at build time.
# PUBLIC_ASK_AI_ENABLED=true

# Lean Pages deploy (no Ask AI UI, no Workers AI / Vectorize bindings):
# npm run deploy:cloudflare:lean

# Wrangler / Workers AI local dev (never commit real tokens)
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
